{
  "name": "greenlight",
  "version": "0.1.0",
  "description": "Open-source AI Approval and Compliance Layer for SMBs",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/views dist/views",
    "start": "node dist/index.js",
    "lint": "eslint . && prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'tests/e2e/**'",
    "test:e2e": "vitest run tests/e2e/",
    "test:perf": "npx tsx tests/perf/seed-and-bench-analytics.ts",
    "test:all": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bullmq": "^5.73.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "msw": "^2.12.14",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
